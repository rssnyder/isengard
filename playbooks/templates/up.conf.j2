[poller]
  debug   = false
  quiet   = false
  plugins = []

[prometheus]
  disable      = false
  http_listen  = "{{ unpoller_prometheus_listen | default('0.0.0.0:9130') }}"
  report_errors = false
  dead_ports   = false

[influxdb]
  disable = true

[loki]
  disable = true

[datadog]
  enable = false

[webserver]
  enable = false

[unifi]
  dynamic = false

[unifi.defaults]
  url        = "{{ unpoller_unifi_url }}"
  user       = "{{ unpoller_unifi_user }}"
  pass       = "{{ unpoller_unifi_pass }}"
  sites      = ["all"]
  save_sites = true
  hash_pii   = false
  save_ids   = false
  save_events = false
  save_alarms = false
  save_anomalies = false
  save_dpi   = false
  save_rogue = false
  verify_ssl = {{ unpoller_verify_ssl | default(false) | lower }}
