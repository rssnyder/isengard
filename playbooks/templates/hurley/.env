APPDATA=/home/riley/appdata

GF_AUTH_GOOGLE_CLIENT_ID="{{ hurley.GF_AUTH_GOOGLE_CLIENT_ID }}"
GF_AUTH_GOOGLE_CLIENT_SECRET="{{ hurley.GF_AUTH_GOOGLE_CLIENT_SECRET }}"

POSTGRES_PASSWORD="{{ hurley.POSTGRES_PASSWORD }}"

MINIO_USER="{{ hurley.MINIO_USER }}"
MINIO_PASSWORD="{{ hurley.MINIO_PASSWORD }}"
